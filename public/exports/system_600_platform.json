      "severity": "principle",
      "rule_strength": "design_principle",
      "description": "System 600 should prioritise repeatable components around element, sub-element, and selected subsystem scale, rather than relying primarily on whole-building or whole-dwelling volumetric modules.\n",
      "preferred_granularity": [
        "element",
        "sub_element",
        "subsystem"
